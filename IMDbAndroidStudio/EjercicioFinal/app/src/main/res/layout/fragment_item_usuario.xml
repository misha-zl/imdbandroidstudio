<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemUsuario"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">


        <ImageView
            android:id="@+id/ivItemFotoUsuario"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="8dp"
            android:background="#F5C518"
            android:contentDescription="Foto usuario"
            android:scaleType="centerCrop"
            android:src="@drawable/no_foto" />


        <TextView
            android:id="@+id/tvItemNombreUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="usuario"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemNombreCompleto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nombre completo"
            android:textColor="#777777"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvItemRolUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Rol"
            android:textColor="#000000"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEditarUsuario"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:backgroundTint="#F5C518"
                android:text="Editar"
                android:textColor="#000000" />

            <Button
                android:id="@+id/btnEliminarUsuario"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#F50000"
                android:text="Eliminar"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>