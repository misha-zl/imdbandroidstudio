<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnVolverListaUsuarios"
            android:layout_width="73dp"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#000000"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir usuario"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <ImageView
            android:id="@+id/ivNuevoUsuarioFoto"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="12dp"
            android:background="#DDDDDD"
            android:scaleType="centerCrop"
            android:contentDescription="Foto nuevo usuario"
            android:src="@drawable/no_foto" /> />

        <Button
            android:id="@+id/btnSeleccionarFotoNuevoUsuario"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="18dp"
            android:backgroundTint="#000000"
            android:text="Seleccionar foto"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNuevoNombre"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nombre completo"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etNuevoUsuario"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nombre de usuario"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etNuevoPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Contraseña"
            android:inputType="textPassword"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etNuevoTelefono"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Teléfono"
            android:inputType="phone"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cbNuevoAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear como administrador"
            android:textColor="#000000"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGuardarNuevoUsuario"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Guardar usuario"
            android:textColor="#000000"
            android:backgroundTint="#F5C518" />

    </LinearLayout>

</ScrollView>